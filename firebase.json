{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "role": {
          ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "orgId": {
          ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child($uid).child('orgId').val() === null"
        }
      }
    },
    "orgs": {
      "$orgId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
        "contacts": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "calls": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "tasks": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "liSnapshots": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "liPosts": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "weeklyGoals": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "weeklyChecklist": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
        },
        "matkon": {
          "projects": {
            "$projectId": {
              ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId"
            }
          },
          "checklistTemplate": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('orgId').val() === $orgId && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager')"
          }
        }
      }
    },
    "hkm": {
      "profiles": {
        ".read": "auth != null",
        "$uid": {
          ".write": "$uid === auth.uid || root.child('hkm/profiles').child(auth.uid).child('role').val() === 'admin'"
        }
      },
      "leads": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "activities": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "knochen_transfers": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "challenges": {
        ".read": "auth != null",
        ".write": "root.child('hkm/profiles').child(auth.uid).child('role').val() === 'admin'"
      },
      "rang_log": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
